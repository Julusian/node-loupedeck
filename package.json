{
  "name": "loupedeck-packages",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@sofie-automation/code-standard-preset": "^3.2.0",
    "@tsconfig/node20": "^20.1.8",
    "@types/lodash": "^4.17.21",
    "@types/node": "^20.19.27",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "lodash": "^4.17.21",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "snyk-nodejs-lockfile-parser": "^2.4.4",
    "typescript": "~5.9.3"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "run build:root --watch",
    "dev:demo": "yarn workspace @loupedeck/web-demo start",
    "build": "run build:root && yarn workspace @loupedeck/web-demo build",
    "build:root": "(rimraf packages/*/dist || true) && tsc --build tsconfig.build.json",
    "test": "run lint && run unit",
    "unit": "jest",
    "lint:raw": "eslint",
    "lint": "run lint:raw packages",
    "lint-fix": "run lint --fix",
    "validate:dependencies": "yarn npm audit && run license-validate",
    "license-validate": "node ./scripts/license-check.mjs"
  },
  "lint-staged": {
    "*.{css,json,md,scss}": [
      "prettier"
    ],
    "*.{ts,tsx,js,jsx}": [
      "yarn lint:raw"
    ]
  },
  "packageManager": "yarn@4.12.0",
  "version": "2.2.1"
}
